{
  "name": "openqa",
  "version": "0.0.7",
  "description": "Agent Harness for Browser Test Automation — write tests in natural language, powered by Claude Code",
  "type": "module",
  "bin": {
    "openqa": "./src/cli/bin.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "keywords": [
    "claude",
    "agent",
    "playwright",
    "browser-automation",
    "ai",
    "testing",
    "mcp",
    "shared-context",
    "bdd",
    "cucumber",
    "gherkin",
    "behavior-driven-development"
  ],
  "author": "Gurvinder Dhillon",
  "homepage": "https://www.openqa.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openqa-labs/openqa.git"
  },
  "license": "MIT",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/mcp": "^0.0.73",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^17.2.3",
    "inquirer": "^9.3.8",
    "js-yaml": "^4.1.1",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@cucumber/cucumber": "^11.0.0",
    "@playwright/test": "^1.57.0",
    "playwright-bdd": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "playwright-bdd": {
      "optional": true
    },
    "@cucumber/cucumber": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "playwright-bdd": "^8.4.1"
  }
}
