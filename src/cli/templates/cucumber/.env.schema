# @defaultSensitive=true @defaultRequired=false
# @generateTypes(lang=ts, path=env.d.ts)
# ---

# URL of the app being tested — passed to the AI agent as context; use to switch between dev/staging/prod
# @type=url @sensitive=false
BASE_URL =

# Username for app authentication — passed to the AI agent as context for login steps
APP_USERNAME =

# Password for app authentication — passed to the AI agent as context; never logged
APP_PASSWORD =

# Set to false to suppress step-by-step agent logs
# @type=boolean @sensitive=false
OPENQA_VERBOSE = true

# Set to false to watch the browser during test runs
# @type=boolean @sensitive=false
HEADLESS = true

# AI Provider API Keys
# For local development, just log in once — no keys needed:
#   Claude Code:  claude login
#   OpenCode:     opencode auth login   (GitLab Duo, GitHub Copilot, Anthropic, OpenAI, Google)
# For CI, set the relevant key below:

ANTHROPIC_API_KEY =

OPENAI_API_KEY =

GOOGLE_API_KEY =
